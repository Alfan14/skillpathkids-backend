<file path="prisma/schema.prisma">
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

//
// ENUMS
//

enum Role {
  PARENT
  TEACHER
}

enum WorksheetVariant {
  FREE
  PAID
}

//
// MODELS
//

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role
  createdAt DateTime @default(now())

  // Relations
  children          ChildProfile[]
  assessmentResults AssessmentResult[]

  @@map("users")
}

model ChildProfile {
  id         String   @id @default(uuid())
  name       String
  ageMonths  Int
  avatarUrl  String?
  createdAt  DateTime @default(now())

  // Parent Relation
  parentId String
  parent   User @relation(fields: [parentId], references: [id], onDelete: Cascade)

  // Assessment Relation
  assessmentResults AssessmentResult[]

  @@map("child_profiles")
}

model Question {
  id         Int      @id @default(autoincrement())
  text       String   @db.Text
  category   String
  iconName   String
  colorClass String
  createdAt  DateTime @default(now())

  @@map("questions")
}

model Tip {
  id          String   @id @default(uuid())
  title       String
  description String   @db.Text
  category    String
  duration    String
  iconName    String
  isMain      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("tips")
}

model Worksheet {
  id           String            @id @default(uuid())
  title        String
  description  String            @db.Text
  url          String
  variant      WorksheetVariant
  badge        String?
  accentColor  String
  iconName     String
  createdAt    DateTime          @default(now())

  @@map("worksheets")
}

model AssessmentResult {
  id              String   @id @default(uuid())
  userId          String
  childProfileId  String?

  answers         Json
  overallScore    Int
  categoryResult  String
  focusSummary    String

  focusAreas      Json
  skillsData      Json

  createdAt       DateTime @default(now())

  user            User @relation(fields: [userId], references: [id])
  childProfile    ChildProfile? @relation(fields: [childProfileId], references: [id])
}
</file>

