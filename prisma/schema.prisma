generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id               String             @id @default(uuid())
  email            String             @unique
  password         String
  name             String
  role             Role
  createdAt        DateTime           @default(now())
  assessmentresult assessmentresult[]
  children         ChildProfile[]

  @@map("users")
}

model ChildProfile {
  id               String             @id @default(uuid())
  name             String
  ageMonths        Int
  avatarUrl        String?
  createdAt        DateTime           @default(now())
  parentId         String
  assessmentresult assessmentresult[]
  parent           User               @relation(fields: [parentId], references: [id], onDelete: Cascade)

  @@index([parentId], map: "child_profiles_parentId_fkey")
  @@map("child_profiles")
}

model Question {
  id         Int           @id @default(autoincrement())
  text       String        @db.Text
  category   String
  iconName   String
  colorClass String
  createdAt  DateTime      @default(now())
  level      QuestionLevel @default(CHILD)

  @@map("questions")
}

model Tip {
  id          String   @id @default(uuid())
  title       String
  description String   @db.Text
  category    String
  duration    String
  iconName    String
  isMain      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("tips")
}

model Worksheet {
  id               String           @id @default(uuid())
  title            String
  description      String           @db.Text
  url              String?
  variant          WorksheetVariant
  badge            String?
  accentColor      String?
  iconName         String?
  createdAt        DateTime         @default(now())
  slug             String           @unique
  shortDescription String?          @db.Text
  category         String
  subCategory      String?
  price            Int              @default(0)
  discountPrice    Int?
  discountPercent  Int?
  mainImageUrl     String?
  galleryImages    Json?
  rating           Float            @default(0)
  reviewCount      Int              @default(0)
  soldCount        Int              @default(0)
  stock            Int?
  badges           Json?
  features         Json?
  specifications   Json?
  shippingInfo     Json?
  isBestSeller     Boolean          @default(false)
  isPromo          Boolean          @default(false)
  isPublished      Boolean          @default(true)
  updatedAt        DateTime         @default(now()) @updatedAt

  @@map("worksheets")
}

model assessmentresult {
  id             String        @id
  userId         String
  childProfileId String?
  answers        Json
  overallScore   Int
  categoryResult String
  focusSummary   String
  focusAreas     Json
  skillsData     Json
  createdAt      DateTime      @default(now())
  child_profiles ChildProfile? @relation(fields: [childProfileId], references: [id], map: "AssessmentResult_childProfileId_fkey")
  users          User          @relation(fields: [userId], references: [id], map: "AssessmentResult_userId_fkey")

  @@index([childProfileId], map: "AssessmentResult_childProfileId_fkey")
  @@index([userId], map: "AssessmentResult_userId_fkey")
}

enum Role {
  PARENT
  STUDENT
  TEACHER
  ADMINISTRATOR
}

enum QuestionLevel {
  CHILD
  TEACHER
}

enum WorksheetVariant {
  FREE
  PAID
}
